# Copy this file to .env.local and fill in values for your environment.
# .env.local is gitignored and must never be committed.
#
# All variables are optional. If none are set, the app runs in mock mode
# using local seed data — no API keys required.

# Phase 2: Context Data API
# Returns company + customer context to pre-fill wizard steps with recommendations.
# VITE_CONTEXT_API_URL=https://internal-api.example.com

# Phase 3: LLM reasoning proxy (server-side — never put an API key here)
# POST body: { systemPrompt, userPrompt } → returns GeneratedMaintenancePlan JSON
# VITE_AI_PROXY_URL=https://internal-api.example.com/v1/maintenance-plan/generate

# Phase 3: LanceDB RAG search (or same BFF as AI proxy)
# POST body: { category, tier, services, ... } → returns top-K similar plans
# VITE_RAG_API_URL=https://internal-api.example.com/v1/rag/similar-plans

# Set to "true" to force mock generation regardless of other env vars.
# Always use this for local dev and demos.
# VITE_FEATURE_MOCK_ONLY=true
